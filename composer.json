{
    "name": "dereuromark/cakephp-tailwind-ui",
    "description": "Tailwind UI helpers for CakePHP",
    "type": "cakephp-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "cakephp/cakephp": "^5.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "TailwindUi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TailwindUi\\Test\\": "tests/",
            "TestApp\\": "tests/test_app/TestApp/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
