<?php
/**
 * @var \{{ namespace }}\View\AppView $this
 * @var \{{ entityClass }} ${{ singularVar }}
 */
?>
{% set associations = {'BelongsTo': [], 'HasOne': [], 'HasMany': [], 'BelongsToMany': []}|merge(associations) %}
{% set fieldsData = Bake.getViewFieldsData(fields, schema, associations) %}
{% set associationFields = fieldsData.associationFields %}
{% set groupedFields = fieldsData.groupedFields %}
{% set pK = '$' ~ singularVar ~ '->' ~ primaryKey[0] %}
<?php
$this->assign('title', __('{{ singularHumanName }}'));
$this->Breadcrumbs->add(__('Home'), '/');
$this->Breadcrumbs->add(__('{{ pluralHumanName }}'), ['action' => 'index']);
$this->Breadcrumbs->add(__('View {{ singularHumanName }}'));
?>
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold"><?= __('{{ singularHumanName }}') ?></h1>
        <?= $this->Breadcrumbs->render() ?>
    </div>
    <div class="flex gap-2">
        <?= $this->Html->link(__('Edit'), ['action' => 'edit', {{ pK|raw }}], ['class' => 'btn btn-primary btn-sm']) ?>
        <?= $this->Form->postLink(__('Delete'), ['action' => 'delete', {{ pK|raw }}], ['confirm' => __('Are you sure you want to delete # {0}?', ${{ singularVar }}->{{ primaryKey[0] }}), 'class' => 'btn btn-error btn-sm btn-outline', 'block' => true]) ?>
        <?= $this->Html->link(__('Back'), ['action' => 'index'], ['class' => 'btn btn-ghost btn-sm']) ?>
    </div>
</div>

<div class="card bg-base-100 shadow mb-4">
    <div class="card-body">
        <table class="table">
{% if groupedFields['string'] %}
{% for field in groupedFields['string'] %}
{% if associationFields[field] is defined %}
{% set details = associationFields[field] %}
            <tr>
                <th class="w-40"><?= __('{{ details.property|humanize }}') ?></th>
                <td><?= ${{ singularVar }}->hasValue('{{ details.property }}') ? $this->Html->link(h(${{ singularVar }}->{{ details.property }}->{{ details.displayField }}), ['controller' => '{{ details.controller }}', 'action' => 'view', ${{ singularVar }}->{{ details.property }}->{{ details.primaryKey[0] }}]) : '' ?></td>
            </tr>
{% else %}
            <tr>
                <th class="w-40"><?= __('{{ field|humanize }}') ?></th>
                <td><?= h(${{ singularVar }}->{{ field }}) ?></td>
            </tr>
{% endif %}
{% endfor %}
{% endif %}
{% if associations.HasOne %}
{% for alias, details in associations.HasOne %}
            <tr>
                <th class="w-40"><?= __('{{ alias|underscore|singularize|humanize }}') ?></th>
                <td><?= ${{ singularVar }}->hasValue('{{ details.property }}') ? $this->Html->link(h(${{ singularVar }}->{{ details.property }}->{{ details.displayField }}), ['controller' => '{{ details.controller }}', 'action' => 'view', ${{ singularVar }}->{{ details.property }}->{{ details.primaryKey[0] }}]) : '' ?></td>
            </tr>
{% endfor %}
{% endif %}
{% if groupedFields.number %}
{% for field in groupedFields.number %}
{% set columnData = Bake.columnData(field, schema) %}
            <tr>
                <th class="w-40"><?= __('{{ field|humanize }}') ?></th>
{% if columnData.null %}
                <td><?= ${{ singularVar }}->{{ field }} === null ? '' : $this->Number->format(${{ singularVar }}->{{ field }}) ?></td>
{% else %}
                <td><?= $this->Number->format(${{ singularVar }}->{{ field }}) ?></td>
{% endif %}
            </tr>
{% endfor %}
{% endif %}
{% if groupedFields.date %}
{% for field in groupedFields.date %}
            <tr>
                <th class="w-40"><?= __('{{ field|humanize }}') ?></th>
                <td><?= h(${{ singularVar }}->{{ field }}) ?></td>
            </tr>
{% endfor %}
{% endif %}
{% if groupedFields.boolean %}
{% for field in groupedFields.boolean %}
            <tr>
                <th class="w-40"><?= __('{{ field|humanize }}') ?></th>
                <td><?= ${{ singularVar }}->{{ field }} ? __('Yes') : __('No'); ?></td>
            </tr>
{% endfor %}
{% endif %}
        </table>
{% if groupedFields.text %}
{% for field in groupedFields.text %}
        <div class="mt-4">
            <h3 class="font-semibold mb-1"><?= __('{{ field|humanize }}') ?></h3>
            <div class="prose max-w-none"><?= $this->Text->autoParagraph(h(${{ singularVar }}->{{ field }})); ?></div>
        </div>
{% endfor %}
{% endif %}
    </div>
</div>
{% set relations = associations.BelongsToMany|merge(associations.HasMany) %}
{% for alias, details in relations %}
{% set otherSingularVar = alias|variable %}
{% set otherPluralHumanName = details.controller|underscore|humanize %}
<div class="card bg-base-100 shadow mb-4">
    <div class="card-body">
        <h2 class="card-title"><?= __('Related {{ otherPluralHumanName }}') ?></h2>
        <?php if (!empty(${{ singularVar }}->{{ details.property }})): ?>
        <div class="overflow-x-auto">
            <table class="table table-zebra w-full">
                <thead>
                    <tr>
{% for field in details.fields %}
                        <th><?= __('{{ field|humanize }}') ?></th>
{% endfor %}
                        <th class="text-right"><?= __('Actions') ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach (${{ singularVar }}->{{ details.property }} as ${{ otherSingularVar }}): ?>
                    <tr>
{% for field in details.fields %}
                        <td><?= h(${{ otherSingularVar }}->{{ field }}) ?></td>
{% endfor %}
{% set otherPk = '$' ~ otherSingularVar ~ '->' ~ details.primaryKey[0] %}
                        <td>
                            <div class="flex gap-1 justify-end">
                                <?= $this->Html->link(__('View'), ['controller' => '{{ details.controller }}', 'action' => 'view', {{ otherPk|raw }}], ['class' => 'btn btn-ghost btn-xs']) ?>
                                <?= $this->Html->link(__('Edit'), ['controller' => '{{ details.controller }}', 'action' => 'edit', {{ otherPk|raw }}], ['class' => 'btn btn-ghost btn-xs']) ?>
                                <?= $this->Form->postLink(__('Delete'), ['controller' => '{{ details.controller }}', 'action' => 'delete', {{ otherPk|raw }}], ['confirm' => __('Are you sure you want to delete # {0}?', {{ otherPk|raw }}), 'class' => 'btn btn-ghost btn-xs text-error', 'block' => true]) ?>
                            </div>
                        </td>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
        <?php endif; ?>
    </div>
</div>
{% endfor %}

<?= $this->fetch('postLink') ?>
